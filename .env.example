# ──────────────────────────────────────────────────────────────────────────
# Required environment variables for the Lenna Portfolio Vercel deployment.
# Copy this file to `.env` for local dev, OR paste each KEY=value pair into
# the Vercel dashboard (Project → Settings → Environment Variables) for
# production. Never commit your real `.env` file to GitHub.
# ──────────────────────────────────────────────────────────────────────────

# Neon Postgres connection string (https://neon.tech).
# Free tier is plenty for this site. Copy the "Pooled connection" string
# from the Neon dashboard. It looks like:
#   postgresql://user:pass@ep-foo-bar.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Resend API key (https://resend.com) for the contact-form email.
# Free tier sends 100 emails/day, plenty for a portfolio.
RESEND_API_KEY=

# Where contact-form emails should be delivered. Defaults to
# lenna.huawork@gmail.com if unset.
CONTACT_TO_EMAIL=lenna.huawork@gmail.com

# REQUIRED. Password for the /admin Studio editor. Pick something long
# (12+ chars) and random — write it down somewhere safe. The admin will
# refuse to log in until this is set. There is no default.
ADMIN_PASSWORD=

# REQUIRED. Secret used to sign admin session tokens. Generate any long
# random string (32+ chars) at https://1password.com/password-generator
# Must be at least 8 characters. There is no default; admin login is
# disabled until this is set.
ADMIN_TOKEN_SECRET=

# Optional: extra CORS origins, comma-separated. Production only needs
# this if you serve the API from a different host than the frontend.
# Vercel runs both on the same domain so you can normally leave this empty.
EXTRA_CORS_ORIGINS=

# Optional alias for a single extra origin (same effect as adding one
# entry to EXTRA_CORS_ORIGINS). Useful when wiring up a separate frontend
# host. Leave empty if not needed.
FRONTEND_ORIGIN=
