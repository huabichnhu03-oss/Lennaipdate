# ──────────────────────────────────────────────────────────────────────────────
# Lenna Portfolio — Environment Variables
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# Required — PostgreSQL connection string (Neon, Supabase, Vercel Postgres, etc.)
# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Required — Password for the /admin panel (minimum 8 characters)
ADMIN_PASSWORD=

# Required — Secret for signing admin session tokens (minimum 8 characters, random string)
ADMIN_TOKEN_SECRET=

# Optional — Resend API key for sending contact-form emails
# Get one at https://resend.com — required only if you want email notifications
RESEND_API_KEY=

# Optional — Email address that receives contact form submissions
# Defaults to lenna.huawork@gmail.com if not set
CONTACT_TO_EMAIL=

# Required for asset uploads — Vercel Blob read/write token
# In Vercel dashboard: Storage → Blob → your store → "Tokens"
# Locally for dev, you can use a token from an existing Vercel project
BLOB_READ_WRITE_TOKEN=
